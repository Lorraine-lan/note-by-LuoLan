<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hgsf.supermarket.dao.ProviderMapper">

    <resultMap id="providerResultMap" type="com.hgsf.supermarket.entity.Provider">
        <id column="id" property="id"/>
        <result column="proCode" property="proCode"/>
        <result column="proName" property="proName"/>
        <result column="proDesc" property="proDesc"/>
        <result column="proContact" property="proContact"/>
        <result column="proPhone" property="proPhone"/>
        <result column="proAddress" property="proAddress"/>
        <result column="proFax" property="proFax"/>
        <result column="createdBy" property="createdBy"/>
        <result column="creationDate" property="creationDate"/>
        <result column="modifyBy" property="modifyBy"/>
        <result column="modifyDate" property="modifyDate"/>
    </resultMap>

    <select id="getByProCode" resultMap="providerResultMap">
        SELECT * FROM smbms_provider WHERE proCode = #{proCode}
    </select>

    <select id="getProviderList" resultMap="providerResultMap">
        SELECT * FROM smbms_provider
        WHERE 1=1
        <if test="proCode != null and proCode != ''">
            AND proCode LIKE CONCAT('%', #{proCode}, '%')
        </if>
        <if test="proName != null and proName != ''">
            AND proName LIKE CONCAT('%', #{proName}, '%')
        </if>
        ORDER BY creationDate DESC
    </select>

    <select id="countProviders" resultType="java.lang.Long">
        SELECT COUNT(*) FROM smbms_provider
        WHERE 1=1
        <if test="proCode != null and proCode != ''">
            AND proCode LIKE CONCAT('%', #{proCode}, '%')
        </if>
        <if test="proName != null and proName != ''">
            AND proName LIKE CONCAT('%', #{proName}, '%')
        </if>
    </select>

    <select id="checkProCodeExists" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM smbms_provider WHERE proCode = #{proCode}
    </select>

    <select id="checkHasBill" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM smbms_bill WHERE providerId = #{providerId}
    </select>

</mapper>